# Site URL (for SEO canonical, og:url)
VITE_SITE_URL=https://bathroom-tiles.com

# Capakey (Vlaanderen): set VITE_ENABLE_CAPAKEY=true or VITE_SITE=debadkamer to show Capakey/perceelnummer in lead form
# VITE_ENABLE_CAPAKEY=false
# VITE_SITE=bathroom-tiles

# Supabase (required for import-tileshop script)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Service role key - ONLY for server-side scripts (import-tileshop). Never expose in client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
